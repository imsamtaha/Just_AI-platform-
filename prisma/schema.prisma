generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ───────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  clerkId        String   @unique
  email          String   @unique
  name           String?
  imageUrl       String?
  role           Role     @default(USER)
  plan           Plan     @default(FREE)
  stripeCustomerId String? @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memory         UserMemory[]
  chats          Chat[]
  messages       Message[]
  projects       Project[]
  tasks          Task[]
  goals          Goal[]
  documents      Document[]
  knowledge      KnowledgeItem[]
  automations    Automation[]
  leads          Lead[]
  contacts       Contact[]
  deals          Deal[]
  subscriptions  Subscription[]
  usageLogs      UsageLog[]
  apiKeys        ApiKey[]
  notifications  Notification[]
  aiGenerations  AiGeneration[]
  teamMembers    TeamMember[]

  @@index([clerkId])
  @@index([email])
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

// ─── Memory System ───────────────────────────────────────────────────────────

model UserMemory {
  id        String   @id @default(cuid())
  userId    String
  type      MemoryType
  key       String
  value     String   @db.Text
  embedding Float[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@index([type])
}

enum MemoryType {
  PREFERENCE
  WRITING_STYLE
  INSTRUCTION
  BUSINESS_INFO
  SAVED_PROMPT
  FACT
}

// ─── AI Chats ────────────────────────────────────────────────────────────────

model Chat {
  id        String   @id @default(cuid())
  userId    String
  title     String
  model     AiModel  @default(GPT4)
  folderId  String?
  pinned    Boolean  @default(false)
  shared    Boolean  @default(false)
  shareId   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder   ChatFolder? @relation(fields: [folderId], references: [id])
  messages Message[]

  @@index([userId])
  @@index([folderId])
}

model ChatFolder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())

  chats Chat[]

  @@index([userId])
}

model Message {
  id        String      @id @default(cuid())
  chatId    String
  userId    String
  role      MessageRole
  content   String      @db.Text
  model     AiModel?
  tokens    Int?
  files     Json?
  createdAt DateTime    @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([userId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AiModel {
  GPT4
  GPT4O
  GPT4O_MINI
  GPT35
  CLAUDE3_OPUS
  CLAUDE3_SONNET
  CLAUDE3_HAIKU
  GEMINI_PRO
  GEMINI_FLASH
  DEEPSEEK_CHAT
  DEEPSEEK_CODER
}

// ─── AI Generations ───────────────────────────────────────────────────────────

model AiGeneration {
  id         String         @id @default(cuid())
  userId     String
  type       GenerationType
  prompt     String         @db.Text
  output     String         @db.Text
  model      AiModel
  tokens     Int            @default(0)
  metadata   Json?
  createdAt  DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

enum GenerationType {
  CHAT
  WRITER
  CONSULTANT
  PLANNER
  AUTOMATION
  KNOWLEDGE
  CRM
}

// ─── Planner ─────────────────────────────────────────────────────────────────

model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?    @db.Text
  status      GoalStatus @default(ACTIVE)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  progress    Int        @default(0)
  aiPlan      String?    @db.Text
  milestones  Milestone[]
  tasks       Task[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Milestone {
  id          String          @id @default(cuid())
  goalId      String
  title       String
  description String?         @db.Text
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ─── Projects & Tasks ────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  userId      String
  name        String
  description String?       @db.Text
  color       String?
  status      ProjectStatus @default(ACTIVE)
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks   Task[]
  members TeamMember[]
  boards  KanbanBoard[]

  @@index([userId])
}

model Task {
  id          String     @id @default(cuid())
  userId      String
  projectId   String?
  goalId      String?
  parentId    String?
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  startDate   DateTime?
  estimatedHours Float?
  actualHours Float?
  tags        String[]
  order       Int        @default(0)
  columnId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project?   @relation(fields: [projectId], references: [id])
  goal     Goal?      @relation(fields: [goalId], references: [id])
  parent   Task?      @relation("SubTasks", fields: [parentId], references: [id])
  subtasks Task[]     @relation("SubTasks")
  column   KanbanColumn? @relation(fields: [columnId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([goalId])
  @@index([status])
}

model KanbanBoard {
  id        String   @id @default(cuid())
  projectId String
  name      String
  createdAt DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns KanbanColumn[]

  @@index([projectId])
}

model KanbanColumn {
  id      String  @id @default(cuid())
  boardId String
  name    String
  color   String?
  order   Int     @default(0)
  limit   Int?

  board KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
  ON_HOLD
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Teams ───────────────────────────────────────────────────────────────────

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  role      TeamRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── Knowledge Base ──────────────────────────────────────────────────────────

model KnowledgeItem {
  id          String            @id @default(cuid())
  userId      String
  title       String
  type        KnowledgeType
  content     String?           @db.Text
  fileUrl     String?
  fileSize    Int?
  mimeType    String?
  embedding   Float[]
  tags        String[]
  processed   Boolean           @default(false)
  chunks      KnowledgeChunk[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model KnowledgeChunk {
  id              String  @id @default(cuid())
  knowledgeItemId String
  content         String  @db.Text
  embedding       Float[]
  chunkIndex      Int
  tokenCount      Int     @default(0)

  item KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)

  @@index([knowledgeItemId])
}

enum KnowledgeType {
  PDF
  DOCX
  PPT
  WEBSITE
  VIDEO
  TEXT
  CSV
  EXCEL
}

// ─── Documents ───────────────────────────────────────────────────────────────

model Document {
  id          String       @id @default(cuid())
  userId      String
  name        String
  description String?
  fileUrl     String?
  mimeType    String?
  fileSize    Int?
  category    String?
  tags        String[]
  isPublic    Boolean      @default(false)
  shareToken  String?      @unique
  version     Int          @default(1)
  versions    DocumentVersion[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  version    Int
  fileUrl    String
  changes    String?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

model Contact {
  id          String   @id @default(cuid())
  userId      String
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  company     String?
  position    String?
  website     String?
  address     String?
  tags        String[]
  notes       String?  @db.Text
  avatarUrl   String?
  leadScore   Int      @default(0)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads Lead[]
  deals Deal[]

  @@index([userId])
  @@index([email])
}

model Lead {
  id          String     @id @default(cuid())
  userId      String
  contactId   String?
  title       String
  description String?    @db.Text
  source      String?
  status      LeadStatus @default(NEW)
  priority    Priority   @default(MEDIUM)
  value       Float?
  aiScore     Int        @default(0)
  aiInsights  String?    @db.Text
  assignedTo  String?
  followUpAt  DateTime?
  closedAt    DateTime?
  tags        String[]
  metadata    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id])

  @@index([userId])
  @@index([status])
}

model Deal {
  id          String     @id @default(cuid())
  userId      String
  contactId   String?
  pipelineId  String?
  title       String
  value       Float      @default(0)
  currency    String     @default("USD")
  status      DealStatus @default(OPEN)
  stage       String?
  probability Int        @default(0)
  closedAt    DateTime?
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact  Contact? @relation(fields: [contactId], references: [id])
  pipeline Pipeline? @relation(fields: [pipelineId], references: [id])

  @@index([userId])
  @@index([status])
}

model Pipeline {
  id        String   @id @default(cuid())
  userId    String
  name      String
  stages    String[]
  createdAt DateTime @default(now())

  deals Deal[]

  @@index([userId])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
  ON_HOLD
}

// ─── Automations ─────────────────────────────────────────────────────────────

model Automation {
  id          String           @id @default(cuid())
  userId      String
  name        String
  description String?
  trigger     Json
  actions     Json
  status      AutomationStatus @default(INACTIVE)
  runCount    Int              @default(0)
  lastRunAt   DateTime?
  logs        AutomationLog[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AutomationLog {
  id           String        @id @default(cuid())
  automationId String
  status       LogStatus
  input        Json?
  output       Json?
  error        String?
  duration     Int?
  startedAt    DateTime      @default(now())
  completedAt  DateTime?

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
}

enum AutomationStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum LogStatus {
  SUCCESS
  FAILURE
  RUNNING
}

// ─── Subscriptions & Billing ─────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  plan                 Plan
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSubscriptionId])
}

model Invoice {
  id              String        @id @default(cuid())
  userId          String
  stripeInvoiceId String        @unique
  amount          Int
  currency        String        @default("usd")
  status          InvoiceStatus
  pdfUrl          String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  @@index([userId])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAST_DUE
  TRIALING
  UNPAID
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  UNCOLLECTIBLE
  VOID
}

// ─── Usage Tracking ──────────────────────────────────────────────────────────

model UsageLog {
  id        String      @id @default(cuid())
  userId    String
  type      UsageType
  tokens    Int         @default(0)
  cost      Float       @default(0)
  model     AiModel?
  metadata  Json?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

enum UsageType {
  AI_CHAT
  AI_WRITER
  AI_PLANNER
  AI_CONSULTANT
  AI_AUTOMATION
  STORAGE
  API_CALL
}

// ─── API Keys ─────────────────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  key         String    @unique
  permissions String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

enum NotificationType {
  SYSTEM
  AI_COMPLETE
  TASK_DUE
  AUTOMATION_RUN
  SUBSCRIPTION
  TEAM_INVITE
}

// ─── System / Admin ───────────────────────────────────────────────────────────

model SystemPrompt {
  id        String   @id @default(cuid())
  name      String
  type      String
  content   String   @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  resourceId String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
